# OpenAI Configuration
OPENAI_API_KEY=sk-proj-your-api-key-here
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_ADVANCED=gpt-4o
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7
OPENAI_TIMEOUT=30

# Database Configuration
# Local development:
POSTGRES_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/resumetailor
# Production (Railway): DATABASE_URL is auto-injected by Railway PostgreSQL service
# DATABASE_URL=postgresql://postgres:password@host:5432/railway

# CORS Configuration (REQUIRED FOR PRODUCTION)
# Comma-separated list of allowed frontend origins
# Local development:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production (Railway): Add your Vercel domain
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Rate Limiting
AI_RATE_LIMIT_PER_MINUTE=60
AI_DAILY_BUDGET_USD=10.00

# Caching (Future Enhancement)
ENABLE_AI_RESPONSE_CACHE=true
CACHE_TTL_SECONDS=3600

# Logging
LOG_LEVEL=INFO

# Analytics Dashboard
ANALYTICS_PASSWORD=admin123
